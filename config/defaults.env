# Mac Optimise — default thresholds (override in config/local.env)

# Disk: warn when free space below this (GB)
DISK_WARN_GB=20
DISK_CRITICAL_GB=10

# Home directory size warn (GB) — informational
HOME_WARN_GB=500

# Cleanup: max age for /tmp files (days)
TMP_MAX_AGE_DAYS=7

# Cursor cache: warn above (MB)
CURSOR_CACHE_WARN_MB=2000

# Node: warn when global npm cache exceeds (MB)
NPM_CACHE_WARN_MB=1000

# Launchd label
LAUNCHD_LABEL=com.mac.optimise.maintain

# Objoli paths (Mac defaults)
OBJOLI_MAC_PATH="${HOME}/objoli"
PULSE_SYNC_PATH="${HOME}/Pulse-Sync"
PULSE_LOOP_PATH="${HOME}/Pulse Loop"

# iCloud Main Music DL Library (Pulse default)
ICLOUD_MAIN_DL="${HOME}/Library/Mobile Documents/com~apple~CloudDocs/Downloads/Main Music DL Library"

# Audio relocate: filename must match one of these (case-insensitive, space-normalized)
AUDIO_RELOCATE_TERMS="chang chang man changman chang-man chang_man"
AUDIO_RELOCATE_SUBDIR="Chang"
