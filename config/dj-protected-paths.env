# DJ app paths — never move, delete, or count as "local audio" for thin-client.
# Matched as substrings on the full file path. Extend in config/local.env if needed.

DJ_PROTECT_ROOTS=(
  "${HOME}/Music/rekordbox"
  "${HOME}/Music/PioneerDJ"
)

DJ_PROTECT_FRAGMENTS=(
  "/Music/rekordbox/"
  "/Music/PioneerDJ/"
  "/Apps/MIXO-Sync/"
  "/DJ.Studio/"
  "/Mixed In Key/"
  "/Library/CloudStorage/Dropbox/rekordbox"
  "/Library/Application Support/Pioneer/"
  "/Library/Application Support/com.mixedinkey."
  "/Library/Application Support/MixedInKey"
)
